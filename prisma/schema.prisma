generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Trip {
  id          String   @id @default(cuid())

  title       String

  country     String?

  startDate   DateTime?

  endDate     DateTime?

  createdAt   DateTime @default(now())
}