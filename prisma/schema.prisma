enum ActivityType {
  TRAVEL
  CHECK_IN
  CHECK_OUT
  EXPLORE
  MEAL
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Trip {
  id String @id @default(cuid())

  title String

  country String?

  startDate DateTime?

  endDate DateTime?

  createdAt DateTime @default(now())

  itineraryItems ItineraryItem[]
}

model ItineraryItem {
  id String @id @default(cuid())

  activity ActivityType

  place String

  date DateTime?

  time String?

  notes String?

  tripId String

  trip Trip @relation(fields: [tripId], references: [id])
}
