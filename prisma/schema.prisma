enum ActivityType {
  TRAVEL
  CHECK_IN
  CHECK_OUT
  EXPLORE
  MEAL
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Trip {
  id String @id @default(cuid())

  title String

  country String?

  startDate DateTime?

  endDate DateTime?

  createdAt DateTime @default(now())

  itineraryItems ItineraryItem[]

  journalEntries JournalEntry[] 

  travelers Traveler[]
}

model ItineraryItem {
  id String @id @default(cuid())

  activity ActivityType

  place String

  date DateTime?

  time String?

  notes String?

  tripId String

  trip Trip @relation(fields: [tripId], references: [id])

  journalEntries JournalEntry[]

}
model JournalEntry {
  id              String   @id @default(cuid())

  title           String

  date            DateTime?

  content         String

  createdAt       DateTime @default(now())

  tripId          String?

  itineraryItemId String?

  trip            Trip? @relation(fields: [tripId], references: [id])

  itineraryItem   ItineraryItem? @relation(fields: [itineraryItemId], references: [id])
}
model Traveler {
  id String @id @default(cuid())

  name String

  tripId String

  trip Trip @relation(fields: [tripId], references: [id])
}